// pulsemdl.rc - Windows resources for the pulsemdl executable.
//
// Embeds the application icon (shown in Explorer / the taskbar) and version
// metadata into the built .exe.
//
// The icon is wired up but optional: CMake only defines PULSEMDL_HAS_ICON when
// studiomdl/resources/pulsemdl.ico exists, so the build still succeeds before
// the .ico is added. Drop pulsemdl.ico into this folder and re-run CMake
// configure to have it embedded.

#include <windows.h>

#ifdef PULSEMDL_HAS_ICON
// ID 1 = the lowest icon resource ID, which is what Explorer uses as the
// executable's display icon.
1 ICON "pulsemdl.ico"
#endif

/////////////////////////////////////////////////////////////////////////////
// Version information. Keep PULSEMDL_VERSION_* in sync with PULSE_MDL_VERSION
// in studiomdl/studiomdl_app.cpp.

#define PULSEMDL_VERSION_MAJOR 0
#define PULSEMDL_VERSION_MINOR 4
#define PULSEMDL_VERSION_PATCH 2
#define PULSEMDL_VERSION_BUILD 0

#define PULSEMDL_VERSION_STR "0.4.2.0"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    PULSEMDL_VERSION_MAJOR,PULSEMDL_VERSION_MINOR,PULSEMDL_VERSION_PATCH,PULSEMDL_VERSION_BUILD
 PRODUCTVERSION PULSEMDL_VERSION_MAJOR,PULSEMDL_VERSION_MINOR,PULSEMDL_VERSION_PATCH,PULSEMDL_VERSION_BUILD
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS      VS_FF_DEBUG
#else
 FILEFLAGS      0x0L
#endif
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0" // U.S. English, Unicode
        BEGIN
            VALUE "CompanyName",      "PulseMDL"
            VALUE "FileDescription",  "PulseMDL - Valve model compiler"
            VALUE "FileVersion",      PULSEMDL_VERSION_STR
            VALUE "InternalName",     "pulsemdl"
            VALUE "OriginalFilename", "pulsemdl.exe"
            VALUE "ProductName",      "PulseMDL"
            VALUE "ProductVersion",   PULSEMDL_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200 // U.S. English, Unicode
    END
END
